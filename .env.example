# Meta / Instagram
VERIFY_TOKEN=replace_with_a_long_random_string
IG_ACCESS_TOKEN=replace_with_your_instagram_user_access_token
IG_ACCOUNT_ID=replace_with_your_numeric_instagram_professional_account_id
META_APP_SECRET=replace_with_your_meta_app_secret
GRAPH_API_VERSION=v25.0

# Free-tier AI from Google AI Studio
GEMINI_API_KEY=replace_with_your_free_gemini_api_key
GEMINI_MODEL=gemini-3.5-flash-lite

# Runtime tuning
WORKER_COUNT=2
MAX_TURNS=12
QUEUE_SIZE=500
DEDUPE_TTL_SECONDS=172800
LOG_LEVEL=INFO
